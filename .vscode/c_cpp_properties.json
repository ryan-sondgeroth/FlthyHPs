{
    "configurations": [
      {
        "name": "Mac",
        "includePath": [
          "${workspaceFolder}/**",
  
          "${env:HOME}/Documents/Arduino/libraries/**",
  
          "${env:HOME}/Library/Arduino15/packages/arduino/hardware/avr/*/cores/arduino",
          "${env:HOME}/Library/Arduino15/packages/arduino/hardware/avr/*/variants/**",
          "${env:HOME}/Library/Arduino15/packages/arduino/hardware/avr/*/libraries/**",
          "${env:HOME}/Library/Arduino15/packages/arduino/tools/avr-gcc/*/avr/include/**"
        ],
        "defines": [
            "ARDUINO=10819",
            "ARDUINO_ARCH_AVR",
            "ARDUINO_AVR_PRO",
            "F_CPU=16000000L"
        ],
        "compilerPath": "${env:HOME}/Library/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino7/bin/avr-g++",
        "cStandard": "c17",
        "cppStandard": "c++17",
        "intelliSenseMode": "macos-gcc-x64"
      }
    ],
    "version": 4
  }
